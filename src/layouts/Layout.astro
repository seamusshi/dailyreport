---
const { title, description, pubDate } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | OpenClaw Daily</title>
    <meta name="description" content={description}>
    <link rel="stylesheet" href="/dailyreport/styles/main.css">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a href="/dailyreport/" class="logo">
                <span class="logo-icon">🔷</span>
                <span class="logo-text">OpenClaw Daily</span>
            </a>
            <nav class="main-nav">
                <a href="/dailyreport/">首页</a>
                <a href="/dailyreport/archive">归档</a>
                <a href="/dailyreport/about">关于</a>
            </nav>
        </div>
    </header>

    <main class="main-content">
        <slot />
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>© 2026 OpenClaw Daily Report · 每日 AI Agent 行业情报</p>
            <p class="footer-meta">自动采集 · 每日更新 · 8:17 AM</p>
        </div>
    </footer>
</body>
</html>
