---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    title: '示例日报 - 2026年3月16日',
    description: '今日 AI Agent 行业动态概览，包括 OpenClaw、Kimi Claw 等产品的最新更新',
    pubDate: '2026-03-16',
    slug: '2026-03-16',
    category: '日报'
  }
];
---

<Layout title="首页" description="OpenClaw Daily Report - 每日 AI Agent 行业情报">
    <div class="hero">
        <div class="container">
            <h1>OpenClaw Daily</h1>
            <p class="hero-desc">每日自动采集 AI Agent 行业资讯</p>
            <p class="hero-meta">涵盖 OpenClaw、WorkBuddy、Kimi Claw、MaxClaw、CoPaw 等主流产品动态</p>
        </div>
    </div>

    <div class="container">
        <section class="latest-section">
            <h2>📰 最新日报</h2>
            <div class="post-list">
                {posts.map(post => (
                    <article class="post-card">
                        <div class="post-meta">
                            <span class="post-category">{post.category}</span>
                            <time>{post.pubDate}</time>
                        </div>
                        <h3><a href={`/dailyreport/posts/${post.slug}`}>{post.title}</a></h3>
                        <p>{post.description}</p>
                    </article>
                ))}
            </div>
        </section>
    </div>
</Layout>
