---
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
    // 这里会从内容集合中读取所有文章
    // 目前返回示例文章
    return [
        {
            params: { slug: '2026-03-16' },
            props: {
                title: 'OpenClaw Daily - 2026年3月16日',
                description: '今日 AI Agent 行业动态概览',
                pubDate: '2026-03-16',
                category: '日报'
            }
        }
    ];
}

const { title, description, pubDate, category } = Astro.props;
---

<PostLayout frontmatter={{ title, description, pubDate, category }}>

